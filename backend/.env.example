# Agentic GTM Command Center Backend Configuration
GEMINI_API_KEY="your_gemini_api_key_here"
SQLITE_DB_PATH="gtm_center.db"
CHROMA_DB_PATH="chroma_db"
HOST="0.0.0.0"
PORT=8000
ENVIRONMENT="development"

# Gmail SMTP - Email Sending Feature
# Step 1: Enable 2FA on your Gmail account
# Step 2: Go to myaccount.google.com/apppasswords
# Step 3: Create an App Password for "Mail"
# Step 4: Paste the 16-character password below (no spaces)
SMTP_EMAIL="your_email@gmail.com"
SMTP_APP_PASSWORD="your_16_char_app_password"
